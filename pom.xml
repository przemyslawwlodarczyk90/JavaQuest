            <artifactId>jsoup</artifactId>
            <version>1.18.1</version>
        </dependency>

        <!-- Caffeine – nowoczesny, wysokowydajny cache in-memory, rozdział _13_libraries. -->
        <dependency>
            <groupId>com.github.ben-manes.caffeine</groupId>
            <artifactId>caffeine</artifactId>
            <version>3.1.8</version>
        </dependency>

        <!-- Picocli – budowa profesjonalnych aplikacji CLI, rozdział _13_libraries. -->
