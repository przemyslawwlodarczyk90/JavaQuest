        <dependency>
            <groupId>org.hibernate.orm</groupId>
            <artifactId>hibernate-jcache</artifactId>
        </dependency>
        <dependency>
            <groupId>org.ehcache</groupId>
            <artifactId>ehcache</artifactId>
        </dependency>

        <!-- Spring Data JPA – repozytoria/Pageable/Sort/@Transactional, rozdział _23_spring_data_jpa.
             Przynosi transytywnie spring-orm/spring-tx/spring-data-commons oraz WLASNA (zarzadzana
             przez ten sam BOM spring-boot-starter-parent) wersje hibernate-core – zweryfikowane
             `mvn dependency:tree`, ROZWIAZALA SIE spojnie z juz obecnymi hibernate-core/-envers/
             -jcache z _12_hibernate (BOM gwarantuje TA SAMA wersje wszedzie), zero konfliktu. -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-data-jpa</artifactId>
        </dependency>

        <!-- Spring Security - filtr bezpieczenstwa/SecurityFilterChain/UserDetailsService/
             PasswordEncoder, rozdzial _24_spring_security. Wersja zarzadzana przez
             spring-boot-starter-parent BOM (spojnie z pozostalymi starterami). -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-security</artifactId>
        </dependency>

        <!-- OAuth2 Resource Server - natywna walidacja tokenow JWT (NimbusJwtDecoder), potrzebna
             do _24_spring_security/Lesson15 (natywna alternatywa dla recznego filtra z Lesson12).
             Wersja zarzadzana przez spring-boot-starter-parent BOM. -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-oauth2-resource-server</artifactId>
        </dependency>

        <!-- Lombok – generowanie boilerplate'u (gettery/settery/konstruktory/builder), rozdział _13_libraries.
             Wersja NADPISANA ponad BOM z spring-boot-starter-parent (tam zarzadzana wersja 1.18.36 nie
             wspiera annotation processingu pod JDK 25 - adnotacje Lomboka byly po cichu ignorowane,
             bez bledu kompilacji, tylko brakiem wygenerowanych metod). Scope "provided" - potrzebny
             tylko przy kompilacji (annotation processing), nie trafia do finalnego artefaktu. -->
        <dependency>
            <groupId>org.projectlombok</groupId>
            <artifactId>lombok</artifactId>
            <version>1.18.42</version>
            <scope>provided</scope>
        </dependency>

        <!-- Apache Commons Lang3/IO/Collections4 – narzędziowe biblioteki uzupełniające JDK, rozdział _13_libraries. -->
        <dependency>
            <groupId>org.apache.commons</groupId>
            <artifactId>commons-lang3</artifactId>
        </dependency>
        <dependency>
            <groupId>commons-io</groupId>
            <artifactId>commons-io</artifactId>
            <version>2.18.0</version>
        </dependency>
        <dependency>
            <groupId>org.apache.commons</groupId>
            <artifactId>commons-collections4</artifactId>
            <version>4.4</version>
        </dependency>

        <!-- Guava – kolekcje niemutowalne, Multimap/Multiset/BiMap, cache, rozdział _13_libraries. -->
        <dependency>
            <groupId>com.google.guava</groupId>
            <artifactId>guava</artifactId>
            <version>33.4.0-jre</version>
        </dependency>

        <!-- OkHttp – nowoczesny klient HTTP, rozdział _13_libraries. -->
        <dependency>
            <groupId>com.squareup.okhttp3</groupId>
            <artifactId>okhttp</artifactId>
            <version>4.12.0</version>
        </dependency>

        <!-- Guice – lekki framework Dependency Injection od Google, rozdział _13_libraries. -->
        <dependency>
            <groupId>com.google.inject</groupId>
            <artifactId>guice</artifactId>
            <version>7.0.0</version>
        </dependency>

        <!-- MapStruct – generowanie mapperów DTO<->encja bez boilerplate'u, rozdział _13_libraries. -->
        <dependency>
            <groupId>org.mapstruct</groupId>
            <artifactId>mapstruct</artifactId>
            <version>1.6.3</version>
        </dependency>

        <!-- MapStruct annotation processor – generuje faktyczną implementację (XxxMapperImpl) w
