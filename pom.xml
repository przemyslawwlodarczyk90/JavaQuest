        </dependency>

        <!-- jBCrypt – samodzielna implementacja BCrypt (bez ciągnięcia spring-security-crypto),
             potrzebna do lekcji o hashowaniu haseł algorytmem BCrypt (rozdział _19_security_basics,
             Lesson03). Wersja zweryfikowana na Maven Central (jedyna nowsza niż 0.3m). -->
        <dependency>
            <groupId>org.mindrot</groupId>
            <artifactId>jbcrypt</artifactId>
            <version>0.4</version>
        </dependency>

        <!-- JJWT – tworzenie/parsowanie/weryfikacja JWT, potrzebne do lekcji o JWT (rozdział
             _19_security_basics, Lesson05). jjwt-jackson integruje się z Jacksonem już obecnym
             transytywnie przez spring-boot-starter-web. Wersje zweryfikowane na Maven Central. -->
        <dependency>
            <groupId>io.jsonwebtoken</groupId>
            <artifactId>jjwt-api</artifactId>
            <version>0.12.6</version>
        </dependency>
        <dependency>
            <groupId>io.jsonwebtoken</groupId>
            <artifactId>jjwt-impl</artifactId>
            <version>0.12.6</version>
            <scope>runtime</scope>
        </dependency>
        <dependency>
            <groupId>io.jsonwebtoken</groupId>
            <artifactId>jjwt-jackson</artifactId>
            <version>0.12.6</version>
            <scope>runtime</scope>
        </dependency>
    </dependencies>

    <build>
        <plugins>
            <plugin>
                <groupId>org.springframework.boot</groupId>
                <artifactId>spring-boot-maven-plugin</artifactId>
            </plugin>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <configuration>
                    <source>21</source>
                    <target>21</target>
                    <!-- fork=true - kompilacja w OSOBNYM procesie javac zamiast in-process (domyslnie
                         fork=false, kompilator dziala w tym samym JVM co Maven). Lombok patchuje
                         wewnetrzne klasy javac przez refleksje - w trybie in-process, na niektorych
                         (zwlaszcza nowszych) JDK ten patch po cichu sie nie udaje (BRAK bledu
                         kompilacji, po prostu wygenerowane gettery/settery/buildery nie powstaja) -
                         wymuszenie prawdziwego, osobnego procesu javac naprawia ten problem. -->
                    <fork>true</fork>
                    <annotationProcessorPaths>
                        <path>
                            <groupId>org.projectlombok</groupId>
                            <artifactId>lombok</artifactId>
                            <version>1.18.42</version>
                        </path>
                        <path>
                            <groupId>org.mapstruct</groupId>
                            <artifactId>mapstruct-processor</artifactId>
                            <version>1.6.3</version>
                        </path>
                    </annotationProcessorPaths>
                </configuration>
            </plugin>
        </plugins>
    </build>

</project>
